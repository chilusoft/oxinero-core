# Monexo / Oxinero – backend .env (project-specific)
# Copy to .env and set values. Deploy script copies this to the server.

# Production host: serve API at oxinero.chilusoft.dev/backend/api
DJANGO_URL_BASE_PREFIX=backend

# Security (set in production)
SECRET_KEY=your-secret-key-here
DEBUG=false
ALLOWED_HOSTS=oxinero.chilusoft.dev,www.oxinero.chilusoft.dev

# CORS & CSRF for production frontend
CORS_ALLOWED_ORIGINS=https://oxinero.chilusoft.dev
CSRF_TRUSTED_ORIGINS=https://oxinero.chilusoft.dev

# Static files (optional; default is backend/staticfiles)
# STATIC_ROOT=/var/www/oxinero/static
